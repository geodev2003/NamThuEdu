APP_NAME="Nam Thu Edu API"
APP_ENV=development
APP_KEY=base64:85bEewWEv/8jR5UIESwQmsI26SluokexS7346uUz0xI=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Ho_Chi_Minh

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
