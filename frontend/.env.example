# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000
VITE_ADDRESS_API=http://localhost:3000/api/address

# App Configuration
VITE_APP_NAME=NamThu Education
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# WebSocket Configuration
VITE_WS_URL=ws://localhost:6001
VITE_WS_KEY=namthuedu

# Feature Flags
VITE_ENABLE_MONITORING=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
VITE_USE_MOCK_DATA=true

# Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png

# Pagination
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# Production Example:
# VITE_API_URL=https://api.namthuedu.com/api
# VITE_API_BASE_URL=https://api.namthuedu.com
# VITE_APP_ENV=production
